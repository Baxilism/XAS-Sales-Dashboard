  const prev = compare==='mom'?getPrevMonth(selectedMonth):getYoYMonth(selectedMonth);
  const sorted = [...data].sort((a,b)=>(b.m[selectedMonth]?.g||0)-(a.m[selectedMonth]?.g||0));
  const body = document.getElementById('storeTableBody');
  const label = compare==='mom'?'MoM':'YoY';
  body.innerHTML = sorted.map((s,i)=>{

  </div>
  <div class="header-right">
    <button class="print-btn" onclick="window.print()">⎙ Print</button>
    <button class="export-btn" onclick="exportReport()">↓ Export Report</button>
  </div>
</div>

<div class="tabs no-print">
  <button class="tab active" onclick="showTab('dashboard',this)">Dashboard</button>
  <button class="tab" onclick="showTab('analysis',this)">Weekly Analysis</button>
</div>

<!-- DASHBOARD TAB -->
<div id="tab-dashboard">

  <div class="month-selector no-print" id="monthSelector"></div>

  <div class="partner-pills no-print" id="partnerPills"></div>

  <div class="filters no-print">
    <div class="filter-group">
      <span class="filter-label">Area</span>
      <select id="areaFilter" onchange="applyFilters()">
        <option value="all">All communities</option>
        <option value="Jakarta - North West Central (NR)">North West Central</option>
        <option value="Jakarta - Tangerang (NR)">Tangerang</option>
        <option value="Jakarta - Bogor Depok (NR)">Bogor Depok</option>
        <option value="Jakarta - Bekasi (NR)">Bekasi</option>
        <option value="Jakarta - Banten (NR)">Banten</option>
        <option value="Jakarta - South East (NR)">South East</option>
      </select>
    </div>
    <div class="filter-sep"></div>
    <div class="filter-group">
      <span class="filter-label">Type</span>
      <select id="typeFilter" onchange="applyFilters()">
        <option value="all">All types</option>
        <option value="Authorized Sail store">Authorized Sail</option>
        <option value="New authorized store">New Authorized</option>
      </select>
    </div>
    <div class="filter-sep"></div>
    <div class="filter-group">
      <span class="filter-label">Compare</span>
      <select id="compareMode" onchange="applyFilters()">
        <option value="mom">MoM</option>
        <option value="yoy">YoY</option>
      </select>
    </div>
  </div>

  <div class="kpi-grid" id="kpiGrid"></div>

  <div class="charts-grid">
    <div class="card">
      <div class="card-title">GMV Trend — Monthly <span id="trendNote"></span></div>
      <div class="chart-wrap" style="height:220px"><canvas id="trendChart"></canvas></div>
    </div>
    <div class="card">
      <div class="card-title">GMV by Partner <span id="partnerMonth"></span></div>
      <div class="legend" id="partnerLegend"></div>
      <div class="chart-wrap" style="height:190px"><canvas id="partnerChart"></canvas></div>
    </div>
  </div>

  <div class="charts-grid2">
    <div class="card">
      <div class="card-title">MoM Change by Store <span>(top 15)</span></div>
      <div class="chart-wrap" id="momChartWrap" style="height:340px"><canvas id="momChart"></canvas></div>
    </div>
    <div class="card">
      <div class="card-title">Achievement Rate Distribution</div>
      <div class="chart-wrap" style="height:200px"><canvas id="achChart"></canvas></div>
      <div style="margin-top:14px;">
        <div class="card-title" style="margin-bottom:10px;">Partner Achievement <span id="partnerAchMonth"></span></div>
        <div id="partnerAchBars"></div>
      </div>
    </div>
  </div>

  <div class="card" style="margin-bottom:12px;">
    <div class="card-title">Store Performance Ranking <span id="tableMonth"></span></div>
    <div class="table-wrap">
      <table>
        <thead><tr>
          <th>#</th><th>Store</th><th>Partner</th><th>Community</th>
          <th>GMV (M)</th><th>vs Target</th><th>MoM / YoY</th>
          <th>Phone SO</th><th>High-end</th><th>Tablet SO</th>
        </tr></thead>
        <tbody id="storeTableBody"></tbody>
      </table>
    </div>
  </div>

</div>

<!-- ANALYSIS TAB -->
<div id="tab-analysis" style="display:none;">
  <div class="analysis-wrap" id="analysisContent"></div>
</div>

</div>


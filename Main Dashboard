// ANALYSIS TAB
function buildAnalysis(){
  const cur = '04-2026';
  const prev = '03-2026';
  const yoy = '04-2025';
  const allStores = STORES.filter(s=>s.m[cur]);

  const totalGMV = allStores.reduce((s,r)=>s+(r.m[cur]?.g||0),0);
  const totalTgt = allStores.reduce((s,r)=>s+(r.m[cur]?.t||0),0);
  const ach = totalGMV/totalTgt*100;
  const prevGMV = allStores.reduce((s,r)=>s+(r.m[prev]?.g||0),0);
  const mom = (totalGMV-prevGMV)/prevGMV*100;
  const totalPhone = allStores.reduce((s,r)=>s+(r.m[cur]?.p||0),0);
  const totalHE = allStores.reduce((s,r)=>s+(r.m[cur]?.h||0),0);

  // Classify each store
  const storeAnalysis = allStores.map(s=>{
    const mo = s.m[cur]||{};
    const pmo = s.m[prev]||{};
    const gmv = mo.g||0, tgt = mo.t||0;
    const achP = tgt>0?gmv/tgt*100:0;
    const momP = pmo.g>0?(gmv-pmo.g)/pmo.g*100:null;
    let status='warn', flag='';
    if(achP>=110&&(momP===null||momP>-10)) { status='great'; flag='🌟 Outperformer'; }
    else if(achP>=100) { status='good'; flag='✅ On Target'; }
    else if(achP>=80) { status='warn'; flag='⚠️ Near Miss'; }
    else { status='bad'; flag='🔴 Below Target'; }
    if(momP!==null&&momP<=-40) flag+=' · ⬇️ Sharp Drop';
    if(momP!==null&&momP>=20) flag+=' · 📈 Strong Trend';
    return {...s, gmv, tgt, achP, momP, flag, status, mo, pmo};
  }).sort((a,b)=>b.gmv-a.gmv);

  const outperformers = storeAnalysis.filter(s=>s.status==='great');
  const onTarget = storeAnalysis.filter(s=>s.status==='good');
  const nearMiss = storeAnalysis.filter(s=>s.status==='warn');
  const belowTarget = storeAnalysis.filter(s=>s.status==='bad');

  // Partner summary
  const partnerSummary = {};
  ALL_PARTNERS.forEach(p=>{
    const ps = storeAnalysis.filter(s=>s.p===p);
    if(!ps.length) return;
    const g=ps.reduce((s,r)=>s+r.gmv,0);
    const t=ps.reduce((s,r)=>s+r.tgt,0);
    partnerSummary[p]={gmv:g,tgt:t,ach:t>0?g/t*100:0,count:ps.length};
  });

  function storeRowHTML(s){
    const achColor = s.achP>=100?'var(--green)':s.achP>=85?'var(--yellow)':'var(--red)';
    const momStr = s.momP!==null?(s.momP>=0?'▲+':'▼')+s.momP.toFixed(1)+'% MoM':'new store';
    const momCol = s.momP===null?'var(--blue)':s.momP>=0?'var(--green)':'var(--red)';
    const name = s.n.replace('Xiaomi Authorized Store ','').replace(' Indonesia','').trim();

    let rec='';
    if(s.achP>=110) rec='Maintain current momentum. Explore upselling high-end and tablet bundles.';
    else if(s.achP>=100) rec='Solid performance. Focus on defending Phone SO and improving high-end mix.';
    else if(s.achP>=80) rec='Close to target. Identify top 2–3 SKUs underperforming vs. plan and address inventory/display gaps.';
    else if(s.achP>=60) rec='Needs intervention. Review staffing levels, promoter activity, and in-store execution urgently.';
    else rec='Critical attention needed. Escalate to partner management — evaluate root cause (traffic, competition, ops issues).';

    if(s.momP!==null&&s.momP<=-40) rec+=' Sharp MoM decline warrants an on-site visit this week.';
    if(s.momP!==null&&s.momP>=20) rec+=' Strong MoM momentum — capture best practices to replicate across partner.';

    return `<div class="store-row ${s.status}">
      <div class="store-row-header">
        <span class="store-row-name">${name}</span>
        <span class="partner-badge" style="background:${PARTNER_COLORS[s.p]||'#888'}22;color:${PARTNER_COLORS[s.p]||'#888'}">${s.p}</span>
        <span style="font-size:11px;color:var(--text3)">${s.flag}</span>
      </div>
      <div class="store-row-meta">
        GMV: <span class="highlight">${fmtM(s.gmv)}M</span> &nbsp;|&nbsp;
        Achievement: <span style="color:${achColor};font-weight:600">${s.tgt>0?s.achP.toFixed(0)+'%':'no target'}</span> &nbsp;|&nbsp;
        <span style="color:${momCol}">${momStr}</span> &nbsp;|&nbsp;
        Phone SO: <span class="highlight">${s.mo.p||0}</span> &nbsp;|&nbsp;
        High-end: <span class="highlight">${s.mo.h||0}</span>
      </div>
      <div class="store-row-body" style="margin-top:5px;">💡 <span class="highlight">Recommendation:</span> ${rec}</div>
    </div>`;
  }

  const html = `
    <div class="analysis-section">
      <div class="section-header">
        <div class="section-icon" style="background:var(--orange-bg)">📊</div>
        <div><div class="section-title">Executive Summary — April 2026</div>

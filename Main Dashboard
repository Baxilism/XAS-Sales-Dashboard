const MONTHS = DATA.months;
const RECENT = DATA.recent_months;
const STORES = DATA.stores;
const MONTHLY = DATA.monthly;
const PM = DATA.partner_monthly;

const PARTNER_COLORS = {
  'PPP REG1':'#4a9eff','PPP REG5':'#b57af5',
  'Telling':'#ff6b35','GTN':'#3dd68c',
  'ITG':'#ffc947','Bumilink':'#ff8fa3',
  'Fonel':'#56d9d9','Sentra':'#a78bfa','Unknown':'#8b96b0'
};

const ALL_PARTNERS = ['PPP REG1','PPP REG5','Telling','GTN','ITG','Bumilink','Fonel','Sentra'];
const COMM_SHORT = {
  'Jakarta - North West Central (NR)':'NW Central',
  'Jakarta - Tangerang (NR)':'Tangerang',
  'Jakarta - Bogor Depok (NR)':'Bogor Depok',
  'Jakarta - Bekasi (NR)':'Bekasi',
  'Jakarta - Banten (NR)':'Banten',
  'Jakarta - South East (NR)':'South East',
};

let selectedMonth = '04-2026';
let activePartners = new Set(['all']);
let charts = {};

function fmt(n){return n>=1e9?(n/1e9).toFixed(2)+'B':(n/1e6).toFixed(0)+'M';}
function fmtM(n){return (n/1e6).toFixed(1);}
function fmtK(n){return Math.round(n/1000).toLocaleString()+'K';}
function shortName(n){
  return n.replace('Xiaomi Authorized Store ','').replace(' Indonesia','')
    .replace(' Jakarta','').replace(' Tangerang','').replace(' Depok','')
    .replace(' Bogor','').replace(' Bekasi','').replace(' Cilegon','')
    .replace('  ',' ').trim().slice(0,28);
}

// Build month selector
function buildMonthSelector(){
  const el = document.getElementById('monthSelector');
  const display = ['Jun','Jul','Aug','Sep','Oct','Nov','Dec','Jan','Feb','Mar','Apr'];
  const months = RECENT;
  el.innerHTML = months.map(m => {
    const parts = m.split('-');
    const mo = parseInt(parts[0]);
    const yr = parts[1];
    const label = new Date(parseInt(yr),mo-1).toLocaleString('en',{month:'short'})+' '+yr.slice(2);
    return `<button class="month-btn ${m===selectedMonth?'active':''}" onclick="setMonth('${m}',this)">${label}</button>`;
  }).join('');
}

function setMonth(m, btn){
  selectedMonth = m;
  document.querySelectorAll('.month-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  applyFilters();
}

// Partner pills
function buildPartnerPills(){
  const el = document.getElementById('partnerPills');
  let html = `<span class="p-pill active" data-p="all" onclick="togglePartner(this,'all')" style="border-color:#ff6b35;background:#ff6b35;">All partners</span>`;
  ALL_PARTNERS.forEach(p => {
    const c = PARTNER_COLORS[p]||'#888';
    html += `<span class="p-pill" data-p="${p}" onclick="togglePartner(this,'${p}')" style="border-color:${c};">${p}</span>`;
  });
  el.innerHTML = html;
}

function togglePartner(el, p){
  if(p==='all'){
    activePartners = new Set(['all']);
    document.querySelectorAll('.p-pill').forEach(b=>b.classList.remove('active'));
    el.classList.add('active');
    el.style.background='#ff6b35';
  } else {
    const allBtn = document.querySelector('.p-pill[data-p="all"]');
    if(activePartners.has('all')){
      activePartners.delete('all');
      allBtn.classList.remove('active');
      allBtn.style.background='transparent';
    }
    if(activePartners.has(p)){
      activePartners.delete(p);
      el.classList.remove('active');
      el.style.background='transparent';
    } else {
      activePartners.add(p);
      el.classList.add('active');
      el.style.background=PARTNER_COLORS[p]||'#888';
    }
    if(activePartners.size===0){
      activePartners.add('all');
      allBtn.classList.add('active');
      allBtn.style.background='#ff6b35';
    }
  }
  applyFilters();
}

function getFiltered(){
  const area = document.getElementById('areaFilter').value;
  const type = document.getElementById('typeFilter').value;
  return STORES.filter(s => {
    const mo = s.m[selectedMonth];
    if(!mo) return false;
    if(area!=='all' && s.c!==area) return false;
    if(type!=='all' && s.tp!==type) return false;
    if(!activePartners.has('all') && !activePartners.has(s.p)) return false;
    return true;
  });
}

function getPrevMonth(m){
  const idx = MONTHS.indexOf(m);
  return idx>0?MONTHS[idx-1]:null;
}

function getYoYMonth(m){
  const parts = m.split('-');
  const mo = parts[0];
  const yr = (parseInt(parts[1])-1).toString();
  const yoy = mo+'-'+yr;
  return MONTHS.includes(yoy)?yoy:null;
}

function applyFilters(){
  const data = getFiltered();
  const compare = document.getElementById('compareMode').value;
  renderKPIs(data, compare);
  renderTrendChart();
  renderPartnerChart(data);
  renderMomChart(data, compare);
  renderAchChart(data);
  renderPartnerAchBars(data);
  renderStoreTable(data, compare);
  document.getElementById('tableMonth').textContent = '· '+selectedMonth;
  document.getElementById('partnerMonth').textContent = '· '+selectedMonth;
  document.getElementById('partnerAchMonth').textContent = '· '+selectedMonth;
}

function renderKPIs(data, compare){
  const cur = selectedMonth;
  const prev = compare==='mom'?getPrevMonth(cur):getYoYMonth(cur);
  const gmv = data.reduce((s,r)=>s+(r.m[cur]?.g||0),0);
  const tgt = data.reduce((s,r)=>s+(r.m[cur]?.t||0),0);
  const ach = tgt>0?gmv/tgt*100:0;
  const phone = data.reduce((s,r)=>s+(r.m[cur]?.p||0),0);
  const he = data.reduce((s,r)=>s+(r.m[cur]?.h||0),0);
  const tab = data.reduce((s,r)=>s+(r.m[cur]?.tb||0),0);
  const stores = data.length;

  let gmvChg = null, achChg = null, phoneChg = null;
  if(prev){
    const prevGmv = data.reduce((s,r)=>s+(r.m[prev]?.g||0),0);
    const prevPhone = data.reduce((s,r)=>s+(r.m[prev]?.p||0),0);
    if(prevGmv>0) gmvChg=(gmv-prevGmv)/prevGmv*100;
    if(prevPhone>0) phoneChg=(phone-prevPhone)/prevPhone*100;
  }

  const label = compare==='mom'?'MoM':'YoY';
  const achCls = ach>=100?'up':ach>=85?'neutral':'down';
  const gmvCls = gmvChg===null?'neutral':gmvChg>=0?'up':'down';
  const phoneCls = phoneChg===null?'neutral':phoneChg>=0?'up':'down';

  document.getElementById('kpiGrid').innerHTML = `
    <div class="kpi orange">
      <div class="kpi-label">Total GMV</div>
      <div class="kpi-value">${fmt(gmv)}</div>
      <div class="kpi-sub ${gmvCls}">${gmvChg!==null?(gmvChg>=0?'▲':'▼')+Math.abs(gmvChg).toFixed(1)+'% '+label:'—'}</div>
    </div>
    <div class="kpi blue">
      <div class="kpi-label">Achievement</div>
      <div class="kpi-value">${ach.toFixed(1)}%</div>
      <div class="kpi-sub ${achCls}">vs ${fmt(tgt)} target</div>
    </div>
    <div class="kpi green">
      <div class="kpi-label">Phone SO</div>
      <div class="kpi-value">${phone.toLocaleString()}</div>
      <div class="kpi-sub ${phoneCls}">${phoneChg!==null?(phoneChg>=0?'▲':'▼')+Math.abs(phoneChg).toFixed(1)+'% '+label:'—'}</div>
    </div>
    <div class="kpi yellow">
      <div class="kpi-label">High-end SO</div>
      <div class="kpi-value">${he.toLocaleString()}</div>
      <div class="kpi-sub neutral">premium devices</div>
    </div>
    <div class="kpi purple">
      <div class="kpi-label">Tablet SO</div>
      <div class="kpi-value">${tab.toLocaleString()}</div>
      <div class="kpi-sub neutral">units</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Stores</div>
      <div class="kpi-value">${stores}</div>
      <div class="kpi-sub neutral">of 50 tracked</div>
    </div>`;
}

function renderTrendChart(){
  const months = RECENT;
  const labels = months.map(m=>{
    const p=m.split('-');return new Date(parseInt(p[1]),parseInt(p[0])-1).toLocaleString('en',{month:'short',year:'2-digit'});
  });
  const gmvData = months.map(m=>{
    const mt = MONTHLY.find(x=>x.mo===m);
    return mt?Math.round(mt.g/1e6):0;
  });
  const tgtData = months.map(m=>{
    const mt = MONTHLY.find(x=>x.mo===m);
    return mt?Math.round(mt.t/1e6):0;
  });
  if(charts.trend) charts.trend.destroy();
  const ctx = document.getElementById('trendChart');
  document.getElementById('trendNote').textContent = '· All stores combined';
  charts.trend = new Chart(ctx,{
    type:'bar',
    data:{
      labels,
      datasets:[
        {label:'GMV',data:gmvData,backgroundColor:months.map(m=>m===selectedMonth?'#ff6b35':'rgba(255,107,53,0.35)'),borderRadius:4,order:2},
        {label:'Target',data:tgtData,type:'line',borderColor:'rgba(255,201,71,0.7)',backgroundColor:'transparent',borderWidth:1.5,pointRadius:3,pointBackgroundColor:'#ffc947',tension:0.3,order:1},
      ]
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>' '+ctx.dataset.label+': IDR '+ctx.raw.toLocaleString()+'M'}}},
      scales:{
        x:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#5a6480',font:{size:11}}},
        y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#5a6480',font:{size:11},callback:v=>v.toLocaleString()+'M'}},
      }
    }
  });
}

function renderPartnerChart(data){
  const partners = ALL_PARTNERS.filter(p=>data.some(s=>s.p===p));
  const values = partners.map(p=>data.filter(s=>s.p===p).reduce((s,r)=>s+(r.m[selectedMonth]?.g||0),0)/1e6);
  const colors = partners.map(p=>PARTNER_COLORS[p]||'#888');
  document.getElementById('partnerLegend').innerHTML = partners.map((p,i)=>`<span class="leg-item"><span class="leg-dot" style="background:${colors[i]}"></span>${p}</span>`).join('');
  if(charts.partner) charts.partner.destroy();
  charts.partner = new Chart(document.getElementById('partnerChart'),{
    type:'doughnut',
    data:{labels:partners,datasets:[{data:values,backgroundColor:colors,borderWidth:0,hoverOffset:4}]},
    options:{responsive:true,maintainAspectRatio:false,cutout:'55%',plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>' '+ctx.label+': '+ctx.raw.toFixed(0)+'M'}}}}
  });
}

function renderMomChart(data, compare){
  const prev = compare==='mom'?getPrevMonth(selectedMonth):getYoYMonth(selectedMonth);
  if(!prev){document.getElementById('momChartWrap').innerHTML='<p style="color:#5a6480;font-size:13px;text-align:center;padding:30px;">No previous period data</p>';return;}
  document.getElementById('momChartWrap').innerHTML='<canvas id="momChart"></canvas>';
  const stores = data.filter(s=>s.m[selectedMonth]&&s.m[prev]&&s.m[prev].g>0);
  stores.sort((a,b)=>{
    const ma=(a.m[selectedMonth].g-a.m[prev].g)/a.m[prev].g;
    const mb=(b.m[selectedMonth].g-b.m[prev].g)/b.m[prev].g;
    return mb-ma;
  });
  const top = stores.slice(0,15);
  const labels = top.map(s=>shortName(s.n));
  const values = top.map(s=>parseFloat(((s.m[selectedMonth].g-s.m[prev].g)/s.m[prev].g*100).toFixed(1)));
  const colors = values.map(v=>v>=0?'rgba(61,214,140,0.75)':'rgba(255,82,82,0.75)');
  const h = Math.max(280, top.length*26+80);
  document.getElementById('momChartWrap').style.height=h+'px';
  charts.mom = new Chart(document.getElementById('momChart'),{
    type:'bar',
    data:{labels,datasets:[{data:values,backgroundColor:colors,borderRadius:3}]},
    options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>' '+(ctx.raw>=0?'+':'')+ctx.raw+'%'}}},
      scales:{x:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#5a6480',font:{size:11},callback:v=>v+'%'}},y:{grid:{display:false},ticks:{color:'#8b96b0',font:{size:11}}}}}
  });
}

function renderAchChart(data){
  const b={'<60%':0,'60-80%':0,'80-100%':0,'100-120%':0,'>120%':0};
  data.forEach(s=>{
    const mo=s.m[selectedMonth];
    if(!mo||mo.t<=0) return;
    const p=mo.g/mo.t*100;
    if(p>=120) b['>120%']++;
    else if(p>=100) b['100-120%']++;
    else if(p>=80) b['80-100%']++;
    else if(p>=60) b['60-80%']++;
    else b['<60%']++;
  });
  if(charts.ach) charts.ach.destroy();
  charts.ach = new Chart(document.getElementById('achChart'),{
    type:'bar',
    data:{labels:Object.keys(b),datasets:[{data:Object.values(b),backgroundColor:['rgba(255,82,82,0.7)','rgba(255,201,71,0.7)','rgba(139,150,176,0.5)','rgba(61,214,140,0.7)','rgba(74,158,255,0.7)'],borderRadius:4}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>' '+ctx.raw+' stores'}}},
      scales:{x:{grid:{display:false},ticks:{color:'#5a6480',font:{size:11}}},y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#5a6480',font:{size:11},stepSize:1}}}}
  });
}

function renderPartnerAchBars(data){
  const el = document.getElementById('partnerAchBars');
  const partners = ALL_PARTNERS.filter(p=>data.some(s=>s.p===p));
  let html='';
  partners.forEach(p=>{
    const pStores = data.filter(s=>s.p===p&&s.m[selectedMonth]);
    if(!pStores.length) return;
    const gmv = pStores.reduce((s,r)=>s+(r.m[selectedMonth]?.g||0),0);
    const tgt = pStores.reduce((s,r)=>s+(r.m[selectedMonth]?.t||0),0);
    const ach = tgt>0?Math.round(gmv/tgt*100):0;
    const barW = Math.min(ach,150)/150*100;
    const c = PARTNER_COLORS[p]||'#888';
    const achColor = ach>=100?'var(--green)':ach>=85?'var(--yellow)':'var(--red)';
    html+=`<div style="margin-bottom:8px;">
      <div style="display:flex;justify-content:space-between;margin-bottom:3px;">
        <span style="font-size:12px;color:${c};font-weight:500;">${p}</span>
        <span style="font-size:12px;font-family:var(--mono);color:${achColor};">${ach}%</span>
      </div>
      <div style="height:5px;background:var(--bg4);border-radius:3px;">
        <div style="height:5px;width:${barW}%;background:${c};border-radius:3px;opacity:0.8;"></div>
      </div>
    </div>`;
  });
  el.innerHTML=html;
}


    const gmv = mo.g||0, tgt = mo.t||0;
    const ach = tgt>0?gmv/tgt*100:0;
    const barW = Math.min(ach,150)/150*100;
    const achColor = ach>=100?'var(--green)':ach>=85?'var(--yellow)':'var(--red)';
    const prevMo = prev?s.m[prev]:null;
